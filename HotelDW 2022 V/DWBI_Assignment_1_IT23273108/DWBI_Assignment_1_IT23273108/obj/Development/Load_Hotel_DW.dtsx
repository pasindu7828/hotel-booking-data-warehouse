      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6B73DBBC-286F-45CC-999A-1ABD74B13454}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET &#xA;    f.required_parking_spaces = s.required_parking_spaces,&#xA;    f.special_requests = s.special_requests,&#xA;    f.previous_cancellations = s.previous_cancellations,&#xA;    f.booking_changes = s.booking_changes,&#xA;    f.days_in_waiting_list = s.days_in_waiting_list&#xA;FROM fact_booking f&#xA;INNER JOIN Hotel_Staging.dbo.Stg_Booking s ON f.booking_id = s.booking_id;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
